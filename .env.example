# Supabase — Plataforma Inmobiliaria Inteligente
# Copia este archivo a .env.local y completa con los valores de tu proyecto
# Supabase (Project Settings > API en el dashboard, o `supabase status` en local).

# URL pública del proyecto Supabase. En desarrollo local con Supabase CLI
# (docker-compose, ver Agente DevOps) suele ser http://127.0.0.1:54321.
NEXT_PUBLIC_SUPABASE_URL=

# Clave anónima (pública) del proyecto — segura para exponer en el browser,
# se apoya en Row Level Security (RLS) para restringir el acceso a datos.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clave de service role (secreta) — bypassea RLS por completo. SOLO usar en
# código server-side (Route Handlers, scripts, jobs). NUNCA exponer al
# cliente ni prefijar con NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=
