# Supabase — Plataforma Inmobiliaria Inteligente
# Copia este archivo a .env.local y completa con los valores de tu proyecto
# Supabase (Project Settings > API en el dashboard, o `supabase status` en local).

# URL pública del proyecto Supabase. En desarrollo local con Supabase CLI
# (docker-compose, ver Agente DevOps) suele ser http://127.0.0.1:54321.
NEXT_PUBLIC_SUPABASE_URL=

# Clave anónima (pública) del proyecto — segura para exponer en el browser,
# se apoya en Row Level Security (RLS) para restringir el acceso a datos.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clave de service role (secreta) — bypassea RLS por completo. SOLO usar en
# código server-side (Route Handlers, scripts, jobs). NUNCA exponer al
# cliente ni prefijar con NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# --- Notificaciones por email (lib/email.ts) ---
# En desarrollo local, deja estas vacías: apunta por default a Mailpit
# (127.0.0.1:54325, el mismo servidor que usa Supabase Auth localmente —
# ver supabase/config.toml `[inbucket] smtp_port`), visible en
# http://127.0.0.1:54324. En producción, configura un proveedor SMTP real.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
# URL pública del sitio, usada en los links de los emails de notificación.
NEXT_PUBLIC_SITE_URL=

# Detectada por un script de una skill local (.agents/skills/ui-ux-pro-max),
# no la usa la app — se declara solo para satisfacer el audit de all-deploy.
COLORTERM=
